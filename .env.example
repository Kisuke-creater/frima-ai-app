# OpenAI API
OPENAI_API_KEY=your-openai-api-key
OPENAI_GENERATE_MODEL=gpt-4.1-mini
OPENAI_MARKET_ANALYSIS_MODEL=gpt-4o-mini

# Optional: remote MCP server for price recommendation and market analysis
# If OPENAI_PRICE_MCP_SERVER_URL is not set, both features fall back to model-only estimation.
OPENAI_PRICE_MCP_SERVER_URL=
OPENAI_PRICE_MCP_SERVER_LABEL=price-research
OPENAI_PRICE_MCP_SERVER_DESCRIPTION=Read-only market and pricing tools for secondhand listing recommendations.
OPENAI_PRICE_MCP_ALLOWED_TOOLS=
OPENAI_PRICE_MCP_AUTHORIZATION=
OPENAI_PRICE_MCP_HEADERS_JSON=

# Firebase (Auth / Firestore)
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-firebase-app-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
